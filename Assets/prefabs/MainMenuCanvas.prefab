# ─── RULES PANEL ───────────────────────────────────────────────────
--- !u!1 &300000
GameObject:
  m_Name: RulesPanel
  m_IsActive: 0
--- !u!224 &300001
RectTransform:
  m_AnchorMin: {x: 0.2, y: 0.1}
  m_AnchorMax: {x: 0.8, y: 0.9}
  m_AnchoredPosition: {x: 0, y: 0}
  m_SizeDelta: {x: 0, y: 0}
--- !u!114 &300002
Image:
  m_color: {r: 0.05, g: 0.08, b: 0.12, a: 0.97}
--- !u!114 &300003
TextMeshProUGUI:
  m_text: "RULES OF THE ROAD\n\n01  Stay within the designated trial track at all times. Crossing lane boundaries results in an immediate penalty.\n\n02  Obey all traffic signals and road signs on the course. Running a red light or ignoring a stop sign will fail the trial.\n\n03  Maintain a safe following distance from obstacles and other vehicles. Collisions deduct points from your score.\n\n04  Perform parking manoeuvres precisely within the marked bay. Tyres must not touch the boundary lines.\n\n05  Complete each trial stage within the allotted time. Exceeding the time limit reduces your final grade.\n\n06  Accumulate 70 or more points out of 100 to pass the trial and receive your licence."
  m_fontSize: 17
  m_color: {r: 0.88, g: 0.85, b: 0.78, a: 1}
  m_alignment: TopLeft
  m_margin: {x: 30, y: 30, z: 30, w: 30}

